TcOMOCnkUERVqQpIsUEtCqCUSGK+yKMN0gitEw==","shasum":"14ba712adbd079e49f33e3a6e93fa830b201af0f","tarball":"https://registry.npmmirror.com/openlayers2dsceneeditor/-/openlayers2dsceneeditor-0.2.0.tgz","fileCount":9,"unpackedSize":2873530,"signatures":[{"keyid":"SHA256:DhQ8wR5APBvFHLF/+Tc+AYvPOdTpcIDqOhxsBHRwC7U","sig":"MEQCIFpcmHrtBLN4LWbYw0roJYJNWFdWgVPCDmxtxnzspQUTAiAtRGkER9Ulav7mPJ3xwM0ZnN4QBJo2ywFNUQEOboyXFw=="}],"size":662108},"_npmUser":{"name":"jxfyjm","email":"424552971@qq.com"},"directories":{},"maintainers":[{"name":"jxfyjm","email":"424552971@qq.com"}],"_npmOperationalInternal":{"host":"s3://npm-registry-packages-npm-production","tmp":"tmp/openlayers2dsceneeditor_0.2.0_1783613488675_0.3872568142650814"},"_hasShrinkwrap":false,"_cnpmcore_publish_time":"2026-07-09T16:11:28.900Z","publish_time":1783613488900,"_source_registry_name":"default"}},"description":"Vue 3 and OpenLayers 2D scenario editor for model deployment, route editing, annotations, playback, and situation display.","maintainers":[{"name":"jxfyjm","email":"424552971@qq.com"}],"readme":"# openlayers2dsceneeditor\r\n\r\n基于 Vue 3 和 OpenLayers 的二维想定编辑与态势显示通用组件库。\r\n\r\n它面向两类场景：\r\n\r\n- **想定编辑**：部署模型、编辑航线、挂载载荷、批量框选、批量移动/旋转、标绘、测量、导入导出。\r\n- **态势显示**：接入外部实时数据，增量更新模型、关系线和态势特效，并支持帧合并器优化高频数据刷新。\r\n\r\n核心库不绑定具体业务规则。宿主系统根据业务判断“谁发现谁、谁锁定谁、谁攻击谁、谁毁伤/失联”，然后调用库提供的 `models`、`relations`、`effects`、`applySituationFrame` 等能力组合视觉效果。\r\n\r\n仓库内置的测试面板仅作为开发版 demo，用于快速预览雷达、干扰、探测、导弹飞行、拦截、毁伤等效果，不代表业务逻辑。\r\n\r\n## 架构边界\r\n\r\n- `mapClass/mapApp.js` 是核心实例，承载模型、关系线、特效、显示配置、性能配置和态势帧同步等正式能力。\r\n- `src/lib/controller.js` 是宿主推荐使用的对外 API，内部转发到 `mapApp` 或地图桥接能力。\r\n- `mapClass/core/sceneStore.js` 是 mapClass 内部场景仓库，保存 `sceneState`、校验、撤销重做和底层数据操作；不建议宿主直接修改内部状态。\r\n- `leftMenu/index.vue`、`leftMenu/demoState.js`、`addModelparms/**` 只服务内置 demo/测试面板；正式核心模块不依赖这些文件。\r\n- 旧的 `views/core/sceneState.js` 已移除，发布能力不再依赖该路径。\r\n\r\n## 发布边界\r\n\r\n推荐作为正式发布入口使用的只有：\r\n\r\n- `ScenarioEditor`\r\n- `createScenarioEditor()`\r\n- `openlayers2dsceneeditor/style.css`\r\n\r\n以下导出当前仍然保留，但属于兼容层，不建议新接入继续依赖：\r\n\r\n- `mapApp`\r\n- `modelList`\r\n- `selectedModel`\r\n- `mapBridge` 的散装函数导出，例如 `startMeasureMode()`、`syncBatchSelectionOnMap()`、`setTemplateDragData()`\r\n\r\n新接入建议统一围绕 `ScenarioEditor` 组件或 `createScenarioEditor()` 返回的 editor 实例组织调用。\r\n\r\n## 特性\r\n\r\n- Vue 3 组件化接入，支持 npm 包发布。\r\n- 支持在线/离线瓦片、局部瓦片区域、多投影初始化配置。\r\n- 支持红蓝双方模型、模型名称显示、航向线、目标指向线。\r\n- 支持编辑模式、态势显示模式、回放模式。\r\n- 支持模型增删改、批量更新、批量移动、批量旋转、批量布局。\r\n- 支持航线编辑、航迹回放、轨迹尾迹。\r\n- 支持点、线、面、文本、禁飞区、军事标绘等标注能力。\r\n- 支持距离/面积测量、地图截图、场景 JSON 导入导出。\r\n- 支持关系线：目标、攻击、探测、通信等。\r\n- 支持态势特效：雷达、干扰、预警、探测、射程、锁定、链路质量、导弹飞行、毁伤、失联、目标发现、目标跟踪、传感器状态、拦截、脱靶、覆盖重叠等。\r\n- 支持高频态势数据的增量更新与可配置帧合并器。\r\n\r\n## 安装\r\n\r\n```bash\r\nnpm i openlayers2dsceneeditor vue\r\n```\r\n\r\n引入样式：\r\n\r\n```js\r\nimport \"openlayers2dsceneeditor/style.css\";\r\n```\r\n\r\n## 快速开始\r\n\r\n### 组件方式\r\n\r\n```vue\r\n<script setup>\r\nimport ScenarioEditor from \"openlayers2dsceneeditor\";\r\nimport \"openlayers2dsceneeditor/style.css\";\r\n\r\nconst resourceOptions = {\r\n  tileUrlTemplate: \"https://your-tile-server/{z}/{x}/{y}.png\",\r\n  modelIconResolver: model =>\r\n    `/assets/units/${model.nation}/${model.iconKey || model.NodeType}.png`,\r\n  templateIconResolver: template =>\r\n    `/assets/templates/${template.templateIcon || template.NodeType}.png`,\r\n  annotationPointIconUrl: \"/assets/common/marker.png\"\r\n};\r\n\r\nconst mapOptions = {\r\n  projection: \"EPSG:3857\",\r\n  center: [116.394926, 39.9125],\r\n  zoom: 6,\r\n  minZoom: 3,\r\n  maxZoom: 18,\r\n  multiWorld: true\r\n};\r\n</script>\r\n\r\n<template>\r\n  <div style=\"width: 100vw; height: 100vh;\">\r\n    <ScenarioEditor\r\n      :resource-options=\"resourceOptions\"\r\n      :map-options=\"mapOptions\"\r\n      :show-workbench=\"false\"\r\n    />\r\n  </div>\r\n</template>\r\n```\r\n\r\n### 控制器方式\r\n\r\n```js\r\nimport { createScenarioEditor } from \"openlayers2dsceneeditor\";\r\n\r\nconst editor = createScenarioEditor();\r\nawait editor.ready();\r\n\r\nawait editor.deployModel(\"radar\", {\r\n  lon: 116.3,\r\n  lat: 39.9,\r\n  nation: \"red\",\r\n  showName: \"红方雷达\"\r\n});\r\n```\r\n\r\n## 组件 Props\r\n\r\n`ScenarioEditor` 支持以下 props：\r\n\r\n| 名称 | 类型 | 默认值 | 说明 |\r\n| --- | --- | --- | --- |\r\n| `showWorkbench` | `boolean` | `false` | 是否显示内置测试/编辑工作台。发布版可关闭，开发版可打开预览效果。 |\r\n| `assetBaseUrl` | `string` | `\"\"` | 静态资源根路径。 |\r\n| `tileUrlTemplate` | `string` | `\"\"` | 地图瓦片地址模板。 |\r\n| `mapOptions` | `object` | `{}` | 地图初始化配置。 |\r\n| `resourceOptions` | `object` | `{}` | 资源解析配置。 |\r\n\r\n## 资源配置\r\n\r\n推荐由宿主应用提供模型图标、模板图标、瓦片地址等资源。\r\n\r\n```js\r\nconst resourceOptions = {\r\n  tileUrlTemplate: \"https://your-map-server/{z}/{x}/{y}.png\",\r\n  assetBaseUrl: \"/assets/openlayers2dsceneeditor/\",\r\n  modelIconResolver: model =>\r\n    `/assets/units/${model.nation}/${model.iconKey || model.NodeType}.png`,\r\n  templateIconResolver: template =>\r\n    `/assets/templates/${template.templateIcon || template.NodeType}.png`,\r\n  annotationPointIconUrl: \"/assets/common/marker.png\"\r\n};\r\n\r\neditor.setResourceOptions(resourceOptions);\r\n```\r\n\r\n说明：\r\n\r\n- `tileUrlTemplate` 需要符合 XYZ 瓦片格式。\r\n- `modelIconResolver(model)` 返回模型图标地址；不返回时会降级为圆点样式。\r\n- `templateIconResolver(template)` 返回模板图标地址。\r\n- `annotationPointIconUrl` 用于点标绘默认图标。\r\n- 发布包默认不绑定宿主业务资源，建议由宿主自行提供。\r\n\r\n## 地图初始化配置\r\n\r\n```vue\r\n<ScenarioEditor\r\n  :map-options=\"{\r\n    projection: 'EPSG:3857',\r\n    center: [120.15, 30.28],\r\n    zoom: 6,\r\n    minZoom: 3,\r\n    maxZoom: 18,\r\n    multiWorld: true,\r\n    smoothExtentConstraint: true,\r\n    localTileRegions: [\r\n      {\r\n        id: 'harbor-a',\r\n        urlTemplate: '/tiles/harbor-a/{z}/{x}/{y}.png',\r\n        extent: [120.10, 30.20, 120.30, 30.36],\r\n        minZoom: 10,\r\n        maxZoom: 18\r\n      }\r\n    ]\r\n  }\"\r\n/>\r\n```\r\n\r\n常用字段：\r\n\r\n- `projection`：地图投影，默认通常为 `EPSG:3857`。\r\n- `center`：初始中心点，经纬度数组。\r\n- `zoom` / `minZoom` / `maxZoom`：缩放级别。\r\n- `multiWorld`：是否允许多世界横向重复。\r\n- `extent`：地图限制范围。\r\n- `localTileRegions`：局部离线瓦片区域。\r\n\r\n## 工作模式\r\n\r\n支持三种模式：\r\n\r\n- `edit`：编辑模式，允许拖拽、部署、航线编辑、批量操作。\r\n- `view`：态势显示模式，禁用编辑交互，适合实时态势展示。\r\n- `playback`：回放模式，适合按时间轴播放历史航迹。\r\n\r\n```js\r\nawait editor.setMode(\"view\");\r\nawait editor.setMode(\"edit\");\r\nawait editor.setMode(\"playback\");\r\n```\r\n\r\n## 显示配置\r\n\r\n```js\r\nawait editor.setDisplayConfig({\r\n  showPopup: true,\r\n  showModelName: true,\r\n  showTargetLine: true,\r\n  headingVisible: {\r\n    red: true,\r\n    blue: true\r\n  },\r\n  targetLineStyle: {\r\n    redColor: \"#ff5252\",\r\n    blueColor: \"#40d8ff\",\r\n    width: 3,\r\n    lineType: \"flowDash\"\r\n  },\r\n  relationLineStyles: {\r\n    attack: {\r\n      redColor: \"#ff5252\",\r\n      blueColor: \"#4aa3ff\",\r\n      width: 3,\r\n      lineType: \"flowDash\"\r\n    },\r\n    communication: {\r\n      redColor: \"#ffd166\",\r\n      blueColor: \"#66e0ff\",\r\n      width: 2,\r\n      lineType: \"dash\"\r\n    }\r\n  },\r\n  effectVisible: {\r\n    radar: true,\r\n    jammer: true,\r\n    missileFlight: true,\r\n    damaged: true\r\n  },\r\n  effectStyles: {\r\n    default: {\r\n      labelColor: \"#ffffff\",\r\n      labelStrokeColor: \"rgba(0,0,0,0.7)\",\r\n      labelStrokeWidth: 3\r\n    },\r\n    radar: {\r\n      color: \"rgba(64, 200, 255, 0.18)\",\r\n      strokeColor: \"rgba(64, 200, 255, 0.9)\",\r\n      scanColor: \"rgba(255,255,255,0.16)\",\r\n      animation: \"scan\"\r\n    },\r\n    linkQuality: {\r\n      qualityColors: {\r\n        good: \"rgba(80, 255, 150, 1)\",\r\n        weak: \"rgba(255, 215, 90, 1)\",\r\n        broken: \"rgba(255, 90, 90, 1)\"\r\n      }\r\n    },\r\n    missileFlight: {\r\n      strokeColor: \"rgba(255, 185, 72, 0.95)\",\r\n      headColor: \"rgba(255, 220, 120, 1)\",\r\n      headStrokeColor: \"rgba(255,255,255,0.95)\",\r\n      width: 5\r\n    },\r\n    damaged: {\r\n      color: \"rgba(255, 80, 40, 0.14)\",\r\n      strokeColor: \"rgba(255, 80, 40, 0.95)\",\r\n      badgeColor: \"rgba(255, 80, 40, 0.98)\",\r\n      badgeRadius: 11\r\n    }\r\n  },\r\n  performance: {\r\n    level: \"balanced\"\r\n  }\r\n});\r\n```\r\n\r\n常用配置：\r\n\r\n- `showPopup`：是否显示模型弹窗。\r\n- `showModelName`：是否在模型图标上方显示名称。\r\n- `showTargetLine`：是否显示模型 `targetUID` 指向线。\r\n- `targetLineStyle`：目标线样式，支持红蓝双方颜色分别配置。\r\n- `relationLineStyles`：关系线样式配置。\r\n- `effectVisible`：按特效类型控制显示隐藏。\r\n- `effectStyles`：全局特效样式配置，支持 `default` 和按特效类型分别覆盖。\r\n- `headingVisible`：按阵营控制航向线显示。\r\n- `performance`：性能等级配置，控制动画刷新频率和动画步长。\r\n\r\n特效样式优先级：内置默认样式 < `display.effectStyles.default` < `display.effectStyles[type]` < 单个 `effect.style`。\r\n因此宿主既可以统一设置全局主题，也可以对某一个具体效果单独覆盖颜色、线宽、动画和徽标样式。\r\n\r\n## 模型数据结构\r\n\r\n模型是态势系统中的基础节点。\r\n\r\n```js\r\nconst model = {\r\n  UID: \"red_radar_001\",\r\n  name: \"雷达站\",\r\n  showName: \"红方雷达 001\",\r\n  NodeType: \"radar\",\r\n  modelType: \"PLATFORM\",\r\n  nation: \"red\",\r\n  lon: 116.35,\r\n  lat: 39.92,\r\n  height: 0,\r\n  speed: 0,\r\n  heading: 90,\r\n  status: \"normal\",\r\n  targetUID: \"blue_ship_001\",\r\n  iconKey: \"radar\",\r\n  line: [],\r\n  routeMeta: {},\r\n  mounts: []\r\n};\r\n```\r\n\r\n常用字段：\r\n\r\n- `UID`：模型唯一标识。\r\n- `lon` / `lat`：经纬度。\r\n- `heading`：航向角，单位度。\r\n- `nation`：阵营，常用 `red` / `blue`。\r\n- `showName`：地图上显示的名称。\r\n- `targetUID`：目标模型 UID，打开目标线后会从当前模型指向目标模型。\r\n- `status`：状态，如 `normal`、`hidden`、`destroyed` 等。\r\n- `line`：航线点数组。\r\n- `mounts`：挂载载荷数组。\r\n\r\n## 模型 API\r\n\r\n```js\r\nawait editor.deployModel(\"radar\", {\r\n  lon: 116.3,\r\n  lat: 39.9,\r\n  nation: \"red\",\r\n  showName: \"雷达 001\"\r\n});\r\n\r\nawait editor.addModel(model);\r\n\r\nawait editor.updateModel(\"red_radar_001\", {\r\n  heading: 120,\r\n  targetUID: \"blue_ship_001\"\r\n});\r\n\r\nawait editor.batchUpdateModels([\r\n  { uid: \"red_radar_001\", patch: { lon: 116.31, lat: 39.91 } },\r\n  { uid: \"blue_ship_001\", patch: { lon: 116.6, lat: 39.95 } }\r\n]);\r\n\r\nawait editor.removeModel(\"red_radar_001\");\r\nawait editor.removeModels([\"red_001\", \"blue_001\"]);\r\n```\r\n\r\n## 关系线\r\n\r\n关系线用于表达模型之间的业务关系，宿主根据业务自行创建。\r\n\r\n支持的常用类型：\r\n\r\n- `target`：目标指向。\r\n- `attack`：攻击关系。\r\n- `detect`：探测关系。\r\n- `communication`：通信关系。\r\n\r\n```js\r\nawait editor.upsertRelations([\r\n  {\r\n    id: \"attack_red_001_blue_001\",\r\n    type: \"attack\",\r\n    sourceUID: \"red_001\",\r\n    targetUID: \"blue_001\",\r\n    label: \"攻击\",\r\n    style: {\r\n      width: 3,\r\n      lineType: \"flowDash\"\r\n    }\r\n  }\r\n]);\r\n\r\nawait editor.removeRelations([\"attack_red_001_blue_001\"]);\r\n```\r\n\r\n## 态势特效\r\n\r\n特效用于表达模型的探测、压制、状态、攻击过程等视觉信息。\r\n\r\n### 支持的特效类型\r\n\r\n范围类：\r\n\r\n- `radar`：雷达扫描。\r\n- `detect`：探测范围。\r\n- `warning`：预警范围。\r\n- `jammer`：干扰范围。\r\n- `weapon`：武器/射程范围。\r\n\r\n状态类：\r\n\r\n- `lock`：锁定效果。\r\n- `damaged`：毁伤状态。\r\n- `lost`：失联状态。\r\n- `discovered`：目标发现，闪点 + 外圈。\r\n- `tracking`：目标跟踪，持续脉冲。\r\n\r\n传感器类：\r\n\r\n- `sensorSearch`：传感器搜索。\r\n- `sensorOff`：传感器关机。\r\n- `sensorSuppressed`：传感器压制。\r\n\r\n链路/攻击过程类：\r\n\r\n- `linkQuality`：链路质量，支持 `good`、`weak`、`broken`。\r\n- `missileFlight`：导弹飞行动画。\r\n- `intercept`：拦截效果，命中点爆炸/命中标识。\r\n- `miss`：脱靶效果，弹道偏离目标。\r\n- `overlap`：覆盖重叠高亮。\r\n\r\n### 几何类型\r\n\r\n```js\r\n// 圆形范围\r\ngeometry: { shape: \"circle\", radius: 80000 }\r\n\r\n// 扇形范围\r\ngeometry: { shape: \"sector\", radius: 120000, angle: 90, direction: 45 }\r\n\r\n// 线形效果\r\ngeometry: { shape: \"line\", targetUID: \"blue_001\" }\r\n\r\n// 锁定框\r\ngeometry: { shape: \"box\", size: 64 }\r\n\r\n// 指定中心点，适合覆盖重叠区\r\ngeometry: { shape: \"circle\", radius: 30000, lon: 116.4, lat: 39.9 }\r\n```\r\n\r\n### 示例\r\n\r\n```js\r\nawait editor.upsertEffects([\r\n  {\r\n    id: \"radar_red_001\",\r\n    type: \"radar\",\r\n    sourceUID: \"red_001\",\r\n    geometry: {\r\n      shape: \"sector\",\r\n      radius: 120000,\r\n      angle: 100\r\n    },\r\n    style: {\r\n      animation: \"scan\",\r\n      color: \"rgba(64, 200, 255, 0.18)\",\r\n      strokeColor: \"rgba(64, 200, 255, 0.85)\"\r\n    },\r\n    label: \"雷达扫描\"\r\n  },\r\n  {\r\n    id: \"missile_red_001_blue_001\",\r\n    type: \"missileFlight\",\r\n    sourceUID: \"red_001\",\r\n    targetUID: \"blue_001\",\r\n    geometry: {\r\n      shape: \"line\",\r\n      targetUID: \"blue_001\"\r\n    },\r\n    style: {\r\n      animation: \"flow\"\r\n    },\r\n    label: \"导弹飞行\"\r\n  },\r\n  {\r\n    id: \"link_red_001_blue_001\",\r\n    type: \"linkQuality\",\r\n    sourceUID: \"red_001\",\r\n    targetUID: \"blue_001\",\r\n    geometry: {\r\n      shape: \"line\",\r\n      targetUID: \"blue_001\"\r\n    },\r\n    style: {\r\n      animation: \"flow\",\r\n      quality: \"weak\"\r\n    },\r\n    label: \"弱链路\"\r\n  }\r\n]);\r\n\r\nawait editor.removeEffects([\"radar_red_001\"]);\r\n```\r\n\r\n### 样式配置项\r\n\r\n态势特效支持两种配置方式：\r\n\r\n- 全局配置：通过 `setDisplayConfig({ effectStyles })` 统一设置主题。\r\n- 单个效果配置：通过每个 effect 的 `style` 覆盖局部表现。\r\n\r\n常用样式字段：\r\n\r\n| 字段 | 说明 |\r\n| --- | --- |\r\n| `color` / `fillColor` | 范围填充色。 |\r\n| `strokeColor` | 范围、线条或外圈颜色。 |\r\n| `width` | 线宽或范围边框宽度。 |\r\n| `lineDash` | 虚线配置，如 `[12, 8]`。 |\r\n| `animation` | 动画类型，常用 `none`、`pulse`、`scan`、`flow`。 |\r\n| `labelColor` | 标签文字颜色。 |\r\n| `labelStrokeColor` | 标签描边颜色。 |\r\n| `labelStrokeWidth` | 标签描边宽度。 |\r\n| `scanColor` / `scanStrokeColor` | 雷达/传感器扫描扇面颜色。 |\r\n| `flashColor` | 目标发现闪点颜色。 |\r\n| `quality` | 链路质量，支持 `good`、`weak`、`broken`。 |\r\n| `qualityColors` | 链路质量颜色映射。 |\r\n| `headColor` | 线类动画移动头部颜色。 |\r\n| `headRadius` | 线类动画移动头部半径。 |\r\n| `headStrokeColor` / `headStrokeWidth` | 移动头部描边。 |\r\n| `hitPointColor` | 拦截命中点颜色。 |\r\n| `missPointColor` | 脱靶偏离点颜色。 |\r\n| `eventPointRadius` | 命中/脱靶事件点大小。 |\r\n| `badgeColor` | 状态徽标颜色。 |\r\n| `badgeFillColor` | 状态徽标填充色。 |\r\n| `badgeRadius` | 状态徽标半径。 |\r\n| `badgeStrokeWidth` | 状态徽标描边宽度。 |\r\n\r\n示例：统一修改发布版态势主题色。\r\n\r\n```js\r\nawait editor.setDisplayConfig({\r\n  effectStyles: {\r\n    default: {\r\n      labelColor: \"#f8fbff\",\r\n      labelStrokeColor: \"rgba(0,0,0,0.72)\",\r\n      labelStrokeWidth: 3\r\n    },\r\n    radar: {\r\n      color: \"rgba(0, 180, 255, 0.14)\",\r\n      strokeColor: \"rgba(0, 220, 255, 0.95)\",\r\n      scanColor: \"rgba(255,255,255,0.18)\"\r\n    },\r\n    jammer: {\r\n      color: \"rgba(180, 80, 255, 0.14)\",\r\n      strokeColor: \"rgba(220, 120, 255, 0.95)\"\r\n    },\r\n    intercept: {\r\n      strokeColor: \"rgba(255,255,255,0.96)\",\r\n      hitPointColor: \"rgba(255, 210, 90, 0.98)\",\r\n      eventPointRadius: 16\r\n    }\r\n  }\r\n});\r\n```\r\n\r\n### 事件型特效\r\n\r\n```js\r\nawait editor.playEventEffect(\"blue_001\", {\r\n  type: \"realistic\",\r\n  duration: 1500\r\n});\r\n```\r\n\r\n## 态势帧接入\r\n\r\n实时态势推荐使用 `applySituationFrame`。它可以一次提交模型、关系、特效、删除项和显示配置。\r\n\r\n```js\r\nawait editor.applySituationFrame({\r\n  updates: [\r\n    {\r\n      uid: \"red_001\",\r\n      patch: {\r\n        lon: 116.35,\r\n        lat: 39.92,\r\n        heading: 90,\r\n        speed: 220\r\n      }\r\n    }\r\n  ],\r\n  relations: [\r\n    {\r\n      id: \"comm_red_001_blue_001\",\r\n      type: \"communication\",\r\n      sourceUID: \"red_001\",\r\n      targetUID: \"blue_001\"\r\n    }\r\n  ],\r\n  effects: [\r\n    {\r\n      id: \"tracking_blue_001\",\r\n      type: \"tracking\",\r\n      sourceUID: \"blue_001\",\r\n      geometry: { shape: \"circle\", radius: 24000 },\r\n      style: { animation: \"pulse\" },\r\n      label: \"目标跟踪\"\r\n    }\r\n  ]\r\n});\r\n```\r\n\r\n帧字段说明：\r\n\r\n| 字段 | 说明 |\r\n| --- | --- |\r\n| `models` | 新增或完整覆盖模型。 |\r\n| `updates` | 按 `{ uid, patch }` 增量更新模型。 |\r\n| `removals` | 删除模型 UID 数组。 |\r\n| `relations` | 新增或更新关系线。 |\r\n| `removedRelations` | 删除关系线 id 数组。 |\r\n| `effects` | 新增或更新态势特效。 |\r\n| `removedEffects` | 删除特效 id 数组。 |\r\n| `display` | 更新显示配置。 |\r\n| `mode` | 切换工作模式。 |\r\n\r\n## 帧合并器\r\n\r\n当宿主通过 WebSocket 或其他数据源高频推送态势时，可以开启帧合并器。它会在短时间窗口内合并多次 `applySituationFrame`，只渲染最新结果，降低 200+ 节点场景下的渲染压力。\r\n\r\n```js\r\neditor.setFrameMergerConfig({\r\n  enabled: true,\r\n  interval: 100,\r\n  maxDelay: 200\r\n});\r\n\r\neditor.applySituationFrame({\r\n  updates: [\r\n    { uid: \"node_1\", patch: { lon: 116.4, lat: 39.9, heading: 80 } }\r\n  ]\r\n});\r\n\r\neditor.applySituationFrame({\r\n  updates: [\r\n    { uid: \"node_1\", patch: { lon: 116.41, lat: 39.91, heading: 82 } }\r\n  ]\r\n});\r\n```\r\n\r\n配置说明：\r\n\r\n- `enabled`：是否启用帧合并器，默认 `false`。\r\n- `interval`：合并窗口，默认 `100` ms。\r\n- `maxDelay`：最大等待时间，默认 `200` ms。\r\n\r\n合并规则：\r\n\r\n- 同一模型多次 `updates` 会合并为最后状态。\r\n- 同一模型 `models` + `updates` 会合并到最终模型对象。\r\n- 同一模型如果后续进入 `removals`，会抵消之前待处理的新增/更新。\r\n- `relations` 和 `effects` 按 `id` 合并，后来的覆盖前面的。\r\n- `removedRelations` 和 `removedEffects` 会抵消同 id 的待新增项。\r\n- `display` 和 `mode` 使用最后一次配置，并触发完整同步。\r\n\r\n手动刷新积压帧：\r\n\r\n```js\r\nawait editor.flushFrameMerger();\r\n```\r\n\r\n某一帧绕过合并：\r\n\r\n```js\r\nawait editor.applySituationFrame(frame, { merge: false });\r\n```\r\n\r\n查看当前配置：\r\n\r\n```js\r\nconst config = editor.getFrameMergerConfig();\r\n```\r\n\r\n## 200 节点性能建议\r\n\r\n- 实时态势优先使用 `applySituationFrame({ updates: [...] })`，不要每帧调用 `sync()` 或 `loadScene()`。\r\n- 高频数据建议开启帧合并器，推荐 `interval: 100`、`maxDelay: 200` 起步。\r\n- 只给重点目标开启动画特效，避免 200 个节点同时开启扫描、脉冲、导弹动画。\r\n- 对于纯位置更新，尽量只传 `lon`、`lat`、`heading`、`speed` 等变化字段。\r\n- 初始化/切换想定使用 `loadScene()`，实时刷新使用 `applySituationFrame()`。\r\n\r\n## 性能等级配置\r\n\r\n发布版宿主可以按场景规模设置性能等级。性能等级主要影响关系线流动动画、扫描/脉冲/导弹等特效动画的刷新频率和步长。\r\n\r\n```js\r\nawait editor.setPerformanceConfig({\r\n  level: \"balanced\"\r\n});\r\n```\r\n\r\n支持的等级：\r\n\r\n| 等级 | 说明 |\r\n| --- | --- |\r\n| `quality` | 画质优先，动画更平滑，默认值。 |\r\n| `balanced` | 平衡模式，适合中等规模态势。 |\r\n| `performance` | 性能优先，降低动画刷新频率，适合 200+ 节点或大量特效。 |\r\n\r\n也可以精细覆盖：\r\n\r\n```js\r\nawait editor.setPerformanceConfig({\r\n  level: \"performance\",\r\n  effectAnimationInterval: 220,\r\n  relationAnimationInterval: 220,\r\n  effectAnimationStep: 2,\r\n  relationFlowStep: -3\r\n});\r\n```\r\n\r\n读取当前实际配置：\r\n\r\n```js\r\nconst performance = editor.getPerformanceConfig();\r\n```\r\n\r\n## 右键菜单扩展\r\n\r\n发布版宿主可以通过右键菜单扩展接入业务操作，例如“设为目标”“查看详情”“下发任务”“播放轨迹”。库只负责菜单展示和地图上下文，业务动作由宿主实现。\r\n\r\n```js\r\neditor.setContextMenuItems([\r\n  {\r\n    id: \"detail\",\r\n    label: \"查看详情\",\r\n    visible: ({ model }) => Boolean(model),\r\n    action: ({ model }) => {\r\n      openDetailPanel(model);\r\n    }\r\n  },\r\n  {\r\n    id: \"set-target\",\r\n    label: \"设为当前目标\",\r\n    visible: ({ model }) => Boolean(model),\r\n    action: async ({ model }) => {\r\n      await editor.updateModel(\"red_001\", {\r\n        targetUID: model.UID\r\n      });\r\n    }\r\n  },\r\n  {\r\n    id: \"remove\",\r\n    label: \"删除模型\",\r\n    danger: true,\r\n    visible: ({ model }) => Boolean(model),\r\n    action: async ({ model }) => {\r\n      await editor.removeModel(model.UID);\r\n    }\r\n  }\r\n]);\r\n```\r\n\r\n菜单项字段：\r\n\r\n| 字段 | 说明 |\r\n| --- | --- |\r\n| `id` | 菜单项唯一标识。 |\r\n| `label` | 菜单文本，也可以是函数 `payload => string`。 |\r\n| `visible` | 是否显示，可以是布尔值或函数。 |\r\n| `disabled` | 是否禁用，可以是布尔值或函数。 |\r\n| `danger` | 是否使用危险操作颜色。 |\r\n| `action` / `onClick` / `handler` | 点击后的业务回调。 |\r\n\r\n右键回调上下文：\r\n\r\n```js\r\neditor.setContextMenuHandler(payload => {\r\n  console.log(payload.coordinate); // { lon, lat }\r\n  console.log(payload.model);      // 命中的模型，没有则为 null\r\n  console.log(payload.feature);    // OpenLayers Feature\r\n  console.log(payload.uid);        // 模型 UID\r\n});\r\n```\r\n\r\n如果只想监听右键但不显示内置菜单，可以只设置 `setContextMenuHandler`，不设置 `setContextMenuItems`。\r\n\r\n关闭内置菜单：\r\n\r\n```js\r\neditor.setContextMenuItems([], { enabled: false });\r\n```\r\n\r\n## 批量编辑\r\n\r\n```js\r\neditor.setBatchSelection([\"red_001\", \"red_002\"]);\r\n\r\nawait editor.batchMoveModels([\"red_001\", \"red_002\"], {\r\n  deltaLon: 0.1,\r\n  deltaLat: 0.05\r\n});\r\n\r\nawait editor.batchSetModelHeading([\"red_001\", \"red_002\"], 90);\r\n\r\nawait editor.batchLayoutModels([\"red_001\", \"red_002\", \"red_003\"], {\r\n  formation: \"grid\",\r\n  center: { lon: 116.4, lat: 39.9 },\r\n  spacing: 0.1,\r\n  columns: 3\r\n});\r\n\r\nawait editor.batchRotateModels([\"red_001\", \"red_002\"], 30);\r\n```\r\n\r\n## 航线与回放\r\n\r\n```js\r\nawait editor.setModelRoute(\r\n  \"red_001\",\r\n  [\r\n    { lon: 116.3, lat: 39.9 },\r\n    { lon: 116.6, lat: 40.0 }\r\n  ],\r\n  { speed: 220 }\r\n);\r\n\r\neditor.setPlaybackConfig({\r\n  maxTrailPoints: 4000\r\n});\r\n\r\neditor.startPlayback();\r\neditor.pausePlayback();\r\nawait editor.seekPlayback(0.5);\r\nawait editor.stopPlayback();\r\n```\r\n\r\n## 标绘与测量\r\n\r\n```js\r\neditor.startAnnotationMode(\"point\", {}, annotation => {\r\n  console.log(\"created\", annotation);\r\n});\r\n\r\neditor.startMeasureMode(\"distance\", result => {\r\n  console.log(result.label);\r\n});\r\n\r\neditor.endMeasure();\r\neditor.cancelTool();\r\n```\r\n\r\n也可以直接通过 API 管理标绘：\r\n\r\n```js\r\nawait editor.addAnnotation({\r\n  id: \"ann_001\",\r\n  type: \"text\",\r\n  text: \"集结区\",\r\n  geometry: {\r\n    type: \"point\",\r\n    coordinates: [116.4, 39.9]\r\n  }\r\n});\r\n\r\nawait editor.updateAnnotation(\"ann_001\", { text: \"新的标注\" });\r\nawait editor.removeAnnotation(\"ann_001\");\r\n```\r\n\r\n## 导入导出\r\n\r\n```js\r\nconst snapshot = editor.getSceneSnapshot();\r\nconst json = editor.exportSceneJson(2);\r\n\r\nawait editor.loadScene(snapshot);\r\nawait editor.resetScene();\r\n\r\neditor.downloadSceneJson(\"scenario.json\");\r\neditor.downloadReport(\"scenario-report.txt\");\r\neditor.exportMapScreenshot(\"map.png\");\r\n```\r\n\r\n## 事件监听\r\n\r\n```js\r\nconst offReady = editor.onReady(mapApp => {\r\n  console.log(\"ready\", mapApp);\r\n});\r\n\r\nconst offSelection = editor.onSelectionChange(feature => {\r\n  console.log(\"selected\", feature?.get(\"UID\"));\r\n});\r\n\r\nconst offRouteSaved = editor.onRouteSaved(({ uid, points }) => {\r\n  console.log(uid, points);\r\n});\r\n\r\nconst offMeasure = editor.onMeasure(result => {\r\n  console.log(result);\r\n});\r\n\r\nconst offAnnotation = editor.onAnnotationCreated(annotation => {\r\n  console.log(annotation);\r\n});\r\n\r\nconst offDrop = editor.onTemplateDrop(payload => {\r\n  console.log(payload.coordinate);\r\n});\r\n\r\noffReady();\r\noffSelection();\r\noffRouteSaved();\r\noffMeasure();\r\noffAnnotation();\r\noffDrop();\r\n```\r\n\r\n## 控制器 API 概览\r\n\r\n### 初始化与状态\r\n\r\n- `init(options)`：初始化地图。\r\n- `ready()`：等待地图初始化完成。\r\n- `sync()`：手动全量同步场景到地图。\r\n- `destroy()`：销毁地图。\r\n- `getMapApp()`：获取底层地图应用实例。\r\n- `getSceneState()`：获取响应式场景状态；仅用于调试或只读观察，业务更新推荐使用控制器方法。\r\n- `getSceneSnapshot()`：获取场景快照。\r\n- `getStatistics()`：获取统计信息。\r\n- `validateScene()`：校验场景。\r\n\r\n### 配置\r\n\r\n- `setResourceOptions(options)` / `getResourceOptions()`：资源配置。\r\n- `setDisplayConfig(patch)`：显示配置。\r\n- `setPerformanceConfig(config)` / `getPerformanceConfig()`：性能等级配置。\r\n- `setContextMenuItems(items, options)` / `setContextMenuHandler(handler)`：右键菜单扩展。\r\n- `setMode(mode)`：切换 `edit` / `view` / `playback`。\r\n- `setPlaybackConfig(patch)`：回放配置。\r\n- `setFrameMergerConfig(config)` / `getFrameMergerConfig()` / `flushFrameMerger()`：帧合并器配置。\r\n- `setLocalTileRegions(regions)` / `addLocalTileRegion(region)` / `removeLocalTileRegion(id)` / `clearLocalTileRegions()` / `getLocalTileRegions()`：局部瓦片区域。\r\n\r\n### 模型\r\n\r\n- `createModelFromTemplate(templateOrKey, overrides)`：从模板创建模型对象。\r\n- `deployModel(templateOrKey, overrides, options)`：从模板部署模型。\r\n- `addModel(model, options)`：添加模型。\r\n- `updateModel(uid, patch, options)`：更新模型。\r\n- `batchUpdateModels(updates, options)`：批量更新模型。\r\n- `upsertModels(models, options)`：批量新增或更新模型。\r\n- `updateModelPosition(uid, position, options)`：更新位置/航向/速度。\r\n- `removeModel(uid, options)` / `removeModels(uids, options)`：删除模型。\r\n- `focusModel(uid)`：聚焦模型。\r\n- `selectModel(uid)`：选择模型。\r\n\r\n### 态势\r\n\r\n- `applySituationFrame(frame, options)`：应用态势帧。\r\n- `upsertRelations(relations, options)` / `removeRelations(ids, options)`：关系线。\r\n- `upsertEffects(effects, options)` / `removeEffects(ids, options)`：态势特效。\r\n- `playEventEffect(target, options)`：播放一次性事件特效。\r\n\r\n### 批量操作\r\n\r\n- `setBatchSelection(uids)` / `clearBatchSelection()` / `getBatchSelection()`：批量选择。\r\n- `batchMoveModels(uids, delta, options)`：批量移动。\r\n- `batchSetModelHeading(uids, heading, options)`：批量设置航向。\r\n- `batchLayoutModels(uids, layout, options)`：批量布局。\r\n- `batchRotateModels(uids, angleDegrees, options)`：批量旋转。\r\n- `startBoxSelectionMode(handler)` / `stopBoxSelectionMode()`：框选模式。\r\n- `startBatchMoveMode(uids, callbacks)` / `startBatchRotateMode(uids, callbacks)` / `stopBatchTransformMode()`：交互式批量变换。\r\n\r\n### 航线、标绘、测量\r\n\r\n- `startRouteEdit(uid)`：开始编辑模型航线。\r\n- `setModelRoute(uid, points, routeMeta, options)`：设置模型航线。\r\n- `addMount(uid, mount, options)` / `removeMount(uid, mountUID, options)`：挂载管理。\r\n- `addAnnotation(annotation, options)` / `updateAnnotation(id, patch, options)` / `removeAnnotation(id, options)`：标绘管理。\r\n- `startAnnotationMode(mode, options, handler)`：开始交互式标绘。\r\n- `startMeasureMode(mode, handler)` / `endMeasure()`：测量。\r\n- `cancelTool()`：取消当前工具。\r\n\r\n### 回放、导出、事件\r\n\r\n- `startPlayback()` / `pausePlayback()` / `stopPlayback()` / `seekPlayback(progress)`：回放控制。\r\n- `exportSceneJson(space)` / `downloadSceneJson(filename)` / `downloadReport(filename)` / `exportMapScreenshot(filename)`：导出能力。\r\n- `onReady(handler)` / `onSelectionChange(handler)` / `onRouteSaved(handler)` / `onMeasure(handler)` / `onAnnotationCreated(handler)` / `onTemplateDrop(handler)`：事件监听。\r\n\r\n## 测试面板说明\r\n\r\n`showWorkbench` 打开后会显示仓库内置测试面板。它用于开发者快速验证：\r\n\r\n- 模型部署、编辑、批量操作。\r\n- 雷达、干扰、预警、探测、射程。\r\n- 锁定、链路质量、导弹飞行、毁伤、失联。\r\n- 目标发现、目标跟踪、传感器搜索/关机/压制。\r\n- 发射链路、拦截效果、脱靶效果、覆盖重叠。\r\n\r\n测试面板只是 demo，不参与宿主业务流程。正式业务建议关闭 `showWorkbench`，由宿主系统调用控制器 API。\r\n\r\n测试面板的演示状态入口位于 `views/leftMenu/demoState.js`。该文件用于隔离 demo 状态与正式发布 API，宿主或正式核心代码不应依赖 `leftMenu/**`、`addModelparms/**`。\r\n\r\n## 本地开发\r\n\r\n```bash\r\nnpm install\r\nnpm run dev\r\n```\r\n\r\n本地开发页面可打开测试工作台，用于预览效果和验证交互。\r\n\r\n## 构建发布\r\n\r\n```bash\r\nnpm run build:lib\r\nnpm publish ./dist --registry=https://registry.npmjs.org/\r\n```\r\n\r\n构建产物输出到 `dist/`，主要包含：\r\n\r\n- `openlayers2dsceneeditor.js`\r\n- `openlayers2dsceneeditor.umd.cjs`\r\n- `style.css`\r\n- `README.md`\r\n\r\n## 设计原则\r\n\r\n- 核心库只提供二维地图、模型、关系、效果、标绘、测量、回放、态势帧更新等通用能力。\r\n- 业务判断由宿主系统完成，库不内置具体作战/行业规则。\r\n- 测试面板是开发者 demo，便于快速预览效果，不代表宿主系统业务流程。\r\n- 高频态势推荐使用增量帧和帧合并器，避免全量重绘。\r\n\r\n## 开发者手册\r\n\r\n本节按正式 npm 包的公开能力组织，适合宿主系统集成、二次封装和排查问题时查阅。\r\n\r\n### 公开导出\r\n\r\n```js\r\nimport ScenarioEditor, {\r\n  ScenarioEditor as NamedScenarioEditor,\r\n  createScenarioEditor,\r\n  createScenarioEditorController,\r\n  createMapEngine,\r\n  createMapContext,\r\n  getResourceOptions,\r\n  setResourceOptions,\r\n  NativeUiPlugin,\r\n  nativeComponents\r\n} from \"openlayers2dsceneeditor\";\r\n\r\nimport \"openlayers2dsceneeditor/style.css\";\r\n```\r\n\r\n| 导出 | 用途 |\r\n| --- | --- |\r\n| `default` / `ScenarioEditor` | Vue 3 地图编辑组件，适合直接嵌入页面。 |\r\n| `createScenarioEditor()` | 创建或获取控制器实例，适合由宿主系统统一驱动地图。 |\r\n| `createScenarioEditorController` | `createScenarioEditor` 的命名兼容别名。 |\r\n| `createMapEngine()` | 创建独立地图引擎，适合多实例、测试或深度定制。 |\r\n| `createMapContext()` | 创建底层上下文，通常只有高级集成需要。 |\r\n| `setResourceOptions()` / `getResourceOptions()` | 全局资源解析配置。 |\r\n| `NativeUiPlugin` / `nativeComponents` | 内置 demo 面板使用的轻量 Vue UI 组件，正式业务可选。 |\r\n\r\n兼容层还保留了 `mapApp`、`modelList`、`selectedModel` 和若干 `mapBridge` 函数导出。它们用于旧项目迁移，新项目建议只依赖 `ScenarioEditor` 和 `createScenarioEditor()`。\r\n\r\n### 组件接入完整示例\r\n\r\n```vue\r\n<script setup>\r\nimport { ref } from \"vue\";\r\nimport { ScenarioEditor } from \"openlayers2dsceneeditor\";\r\nimport \"openlayers2dsceneeditor/style.css\";\r\n\r\nconst editorRef = ref(null);\r\n\r\nconst resourceOptions = {\r\n  assetBaseUrl: \"/openlayers2dsceneeditor/\",\r\n  tileUrlTemplate: \"https://tile.example.com/{z}/{x}/{y}.png\",\r\n  modelIconResolver: model => `/icons/${model.nation}/${model.iconKey}.png`,\r\n  templateIconResolver: template => `/icons/templates/${template.NodeType}.png`,\r\n  annotationPointIconUrl: \"/icons/marker.png\"\r\n};\r\n\r\nconst mapOptions = {\r\n  projection: \"EPSG:3857\",\r\n  center: [116.394926, 39.9125],\r\n  zoom: 6,\r\n  minZoom: 3,\r\n  maxZoom: 18,\r\n  multiWorld: true\r\n};\r\n</script>\r\n\r\n<template>\r\n  <div ref=\"editorRef\" style=\"height: 100vh;\">\r\n    <ScenarioEditor\r\n      :resource-options=\"resourceOptions\"\r\n      :map-options=\"mapOptions\"\r\n      :show-workbench=\"false\"\r\n    />\r\n  </div>\r\n</template>\r\n```\r\n\r\n### 控制器接入完整示例\r\n\r\n```js\r\nimport { createScenarioEditor } from \"openlayers2dsceneeditor\";\r\nimport \"openlayers2dsceneeditor/style.css\";\r\n\r\nconst editor = createScenarioEditor();\r\n\r\neditor.configureSceneRuntime({\r\n  templates: [\r\n    {\r\n      NodeType: \"radar\",\r\n      name: \"雷达\",\r\n      modelType: \"RADAR\",\r\n      templateCategory: \"sensor\",\r\n      nation: \"red\",\r\n      iconKey: \"default\"\r\n    }\r\n  ],\r\n  mountCompatibility: {\r\n    AIRCRAFT: [\"MISSILE\", \"POD\"]\r\n  },\r\n  defaultEffectPresets: {\r\n    radar: {\r\n      type: \"radar\",\r\n      geometry: { radius: 80000, startAngle: -45, endAngle: 45 },\r\n      style: { color: \"rgba(0, 210, 255, 0.25)\" }\r\n    }\r\n  }\r\n});\r\n\r\neditor.init({\r\n  target: document.getElementById(\"map\"),\r\n  tileUrlTemplate: \"https://tile.example.com/{z}/{x}/{y}.png\",\r\n  center: [116.394926, 39.9125],\r\n  zoom: 6\r\n});\r\n\r\nawait editor.ready();\r\n\r\nconst radar = await editor.deployModel(\"radar\", {\r\n  UID: \"red_radar_001\",\r\n  lon: 116.35,\r\n  lat: 39.92,\r\n  showName: \"红方雷达\"\r\n});\r\n\r\nawait editor.upsertEffects({\r\n  id: \"radar_scan_red_radar_001\",\r\n  type: \"radar\",\r\n  sourceUID: radar.UID,\r\n  geometry: { radius: 80000 }\r\n});\r\n```\r\n\r\n### createScenarioEditor 选项\r\n\r\n```js\r\nconst editor = createScenarioEditor({\r\n  engine,\r\n  context,\r\n  mapApp,\r\n  bridge\r\n});\r\n```\r\n\r\n| 选项 | 说明 |\r\n| --- | --- |\r\n| `engine` | `createMapEngine()` 返回的地图引擎。传入后会创建独立控制器。 |\r\n| `context` | 自定义地图上下文。 |\r\n| `mapApp` | 自定义底层地图应用实例，常用于测试或高级嵌入。 |\r\n| `bridge` | 自定义地图桥接对象，用于替换默认交互实现。 |\r\n\r\n不传任何选项时，`createScenarioEditor()` 返回共享控制器实例，适合单地图应用。\r\n\r\n### 场景数据结构\r\n\r\n```js\r\nconst scene = {\r\n  mode: \"edit\",\r\n  metadata: {\r\n    name: \"联合想定\",\r\n    description: \"\",\r\n    author: \"\",\r\n    updatedAt: \"2026-07-03T00:00:00.000Z\"\r\n  },\r\n  models: [],\r\n  relations: [],\r\n  effects: [],\r\n  annotations: [],\r\n  selectionModelUID: null,\r\n  selectionAnnotationId: null,\r\n  display: {},\r\n  permissions: {\r\n    editable: true,\r\n    role: \"planner\"\r\n  },\r\n  playback: {\r\n    playing: false,\r\n    speed: 1,\r\n    progress: 0,\r\n    duration: 120,\r\n    elapsed: 0,\r\n    currentTimeLabel: \"T+00:00\",\r\n    maxTrailPoints: 4000\r\n  },\r\n  validation: []\r\n};\r\n```\r\n\r\n### Model 数据结构\r\n\r\n```js\r\nconst model = {\r\n  UID: \"red_001\",\r\n  id: \"red_001\",\r\n  name: \"Fighter\",\r\n  showName: \"红方战机 1\",\r\n  NodeType: \"fighter\",\r\n  modelType: \"AIRCRAFT\",\r\n  templateCategory: \"platform\",\r\n  nation: \"red\",\r\n  side: \"red\",\r\n  lon: 116.35,\r\n  lat: 39.92,\r\n  height: 8000,\r\n  speed: 250,\r\n  heading: 90,\r\n  targetUID: \"blue_001\",\r\n  status: \"normal\",\r\n  visible: true,\r\n  mountable: true,\r\n  iconKey: \"fighter\",\r\n  templateIcon: \"fighter\",\r\n  line: [\r\n    { lon: 116.35, lat: 39.92 },\r\n    { lon: 116.8, lat: 40.1 }\r\n  ],\r\n  routeMeta: {\r\n    name: \"route-1\",\r\n    speed: 250,\r\n    altitude: 8000\r\n  },\r\n  mounts: [],\r\n  tags: [\"important\"],\r\n  meta: {\r\n    source: \"business-system\"\r\n  }\r\n};\r\n```\r\n\r\n常用字段说明：\r\n\r\n| 字段 | 说明 |\r\n| --- | --- |\r\n| `UID` | 业务唯一标识，模型更新、删除、关系线和特效绑定都依赖它。 |\r\n| `NodeType` | 模板类型或图标类型。 |\r\n| `modelType` | 业务模型类别，挂载兼容性会使用它。 |\r\n| `nation` / `side` | 阵营字段，通常为 `red`、`blue`、`white` 或业务自定义值。 |\r\n| `lon` / `lat` | WGS84 经纬度。 |\r\n| `height` / `speed` / `heading` | 高度、速度、航向。 |\r\n| `targetUID` | 目标指向线使用的目标模型 UID。 |\r\n| `line` | 航线点数组。 |\r\n| `mounts` | 已挂载载荷。 |\r\n| `meta` | 宿主系统自定义扩展字段。 |\r\n\r\n### Relation 数据结构\r\n\r\n```js\r\nconst relation = {\r\n  id: \"attack_red_001_blue_001\",\r\n  type: \"attack\",\r\n  sourceUID: \"red_001\",\r\n  targetUID: \"blue_001\",\r\n  visible: true,\r\n  label: \"攻击\",\r\n  style: {\r\n    color: \"#ff5252\",\r\n    width: 3,\r\n    lineType: \"flowDash\"\r\n  }\r\n};\r\n```\r\n\r\n`type` 可使用 `target`、`attack`、`detect`、`communication`、`lock` 等业务类型。显示样式由 `display.relationLineStyles[type]` 或 `relation.style` 决定。\r\n\r\n### Effect 数据结构\r\n\r\n```js\r\nconst effect = {\r\n  id: \"radar_red_001\",\r\n  type: \"radar\",\r\n  sourceUID: \"red_001\",\r\n  visible: true,\r\n  label: \"雷达扫描\",\r\n  geometry: {\r\n    radius: 80000,\r\n    startAngle: -60,\r\n    endAngle: 60\r\n  },\r\n  style: {\r\n    color: \"rgba(0, 210, 255, 0.22)\",\r\n    outlineColor: \"#00d2ff\"\r\n  },\r\n  meta: {}\r\n};\r\n```\r\n\r\n常用 `type` 包括 `radar`、`jam`、`warning`、`detect`、`range`、`lock`、`linkQuality`、`missileFlight`、`damage`、`lost`、`discovered`、`tracking`、`sensorStatus`、`intercept`、`miss`、`coverageOverlap`。宿主可以自定义 `type`，只要提供对应样式和几何字段。\r\n\r\n### Annotation 数据结构\r\n\r\n```js\r\nconst annotation = {\r\n  id: \"ann_001\",\r\n  name: \"禁飞区\",\r\n  type: \"polygon\",\r\n  shape: \"custom\",\r\n  category: \"operation\",\r\n  text: \"禁飞区\",\r\n  geometry: {\r\n    type: \"polygon\",\r\n    coordinates: [\r\n      [116.2, 39.8],\r\n      [116.6, 39.8],\r\n      [116.6, 40.1],\r\n      [116.2, 40.1],\r\n      [116.2, 39.8]\r\n    ]\r\n  },\r\n  style: {\r\n    strokeColor: \"#ff5252\",\r\n    fillColor: \"rgba(255,82,82,0.18)\",\r\n    strokeWidth: 2\r\n  }\r\n};\r\n```\r\n\r\n### 控制器方法详表\r\n\r\n| 方法 | 参数 | 返回 | 说明 |\r\n| --- | --- | --- | --- |\r\n| `init(options)` | 地图初始化选项 | `void` | 初始化地图，`options.target` 必填。 |\r\n| `ready()` | 无 | `Promise` | 等待地图可用。 |\r\n| `sync()` | 无 | `Promise` | 全量同步当前场景到地图。 |\r\n| `destroy()` | 无 | `void` | 销毁地图和交互。 |\r\n| `getContext()` | 无 | `object` | 获取地图上下文。 |\r\n| `getEngine()` | 无 | `object` | 获取地图引擎。 |\r\n| `getMapApp()` | 无 | `MapApp` | 获取底层地图应用。 |\r\n| `getSceneState()` | 无 | `object` | 获取响应式场景状态。 |\r\n| `getSceneSnapshot()` | 无 | `object` | 获取可序列化场景快照。 |\r\n| `loadScene(snapshot, options)` | 场景快照 | `Promise` | 加载完整场景。 |\r\n| `resetScene()` | 无 | `Promise` | 重置为空场景。 |\r\n| `setMetadata(patch)` | 元数据补丁 | `Promise<object>` | 更新场景元数据。 |\r\n| `getTemplates()` | 无 | `array` | 获取模型模板列表。 |\r\n| `setTemplates(templates)` | 模板数组 | `array` | 设置模板列表。 |\r\n| `configureSceneRuntime(config)` | 运行时配置 | `object` | 一次性设置模板、挂载规则、校验器、默认特效。 |\r\n| `setMountCompatibility(map)` | 兼容性映射 | `object` | 设置宿主类型可挂载的载荷类型。 |\r\n| `setMountValidator(fn)` | 校验函数 | `function \\| null` | 自定义挂载校验。 |\r\n| `setSceneValidators(fns)` | 校验函数数组 | `array` | 自定义场景校验。 |\r\n| `setDefaultEffectPresets(presets)` | 默认特效映射 | `object` | 设置模型默认特效。 |\r\n| `validateScene()` | 无 | `array` | 返回校验问题列表。 |\r\n| `getHistoryState()` | 无 | `object` | 获取撤销/重做状态。 |\r\n| `undo()` | 无 | `Promise<boolean>` | 撤销一次场景修改。 |\r\n| `redo()` | 无 | `Promise<boolean>` | 重做一次场景修改。 |\r\n| `setResourceOptions(options)` | 资源配置 | `Promise<object>` | 设置瓦片、图标、资源根路径。 |\r\n| `getResourceOptions()` | 无 | `object` | 读取资源配置。 |\r\n| `setDisplayConfig(patch)` | 显示配置补丁 | `Promise<object>` | 更新名称、航向线、关系线、特效样式等显示配置。 |\r\n| `setPerformanceConfig(config)` | 性能配置 | `Promise<object>` | 设置 `quality`、`balanced`、`performance` 或细粒度动画参数。 |\r\n| `getPerformanceConfig()` | 无 | `object` | 读取实际性能配置。 |\r\n| `setMode(mode)` | `edit`、`view`、`playback` | `Promise<string>` | 切换工作模式。 |\r\n| `setContextMenuItems(items, options)` | 菜单项数组 | `array` | 设置右键菜单。 |\r\n| `setContextMenuHandler(handler)` | 处理函数 | `function` | 自定义右键菜单处理。 |\r\n| `setLocalTileRegions(regions)` | 区域数组 | `array` | 设置局部离线瓦片区域。 |\r\n| `addLocalTileRegion(region)` | 单个区域 | `object` | 新增局部瓦片区域。 |\r\n| `removeLocalTileRegion(id)` | 区域 id | `boolean` | 删除局部瓦片区域。 |\r\n| `clearLocalTileRegions()` | 无 | `array` | 清空局部瓦片区域。 |\r\n| `getLocalTileRegions()` | 无 | `array` | 读取局部瓦片区域。 |\r\n| `createModelFromTemplate(templateOrKey, overrides)` | 模板或模板 key | `object \\| null` | 只创建模型对象，不加入场景。 |\r\n| `canMountTemplateOnModel(templateOrKey, uidOrModel)` | 模板、模型 | `boolean` | 判断模板是否可挂载到模型。 |\r\n| `setTemplateDragData(event, templateOrKey, extra)` | 拖拽事件、模板 | `void` | 给拖拽事件写入模板数据。 |\r\n| `deployModel(templateOrKey, overrides, options)` | 模板、覆盖字段 | `Promise<object>` | 从模板创建并加入场景。 |\r\n| `addModel(model, options)` | 模型对象 | `Promise<object>` | 添加模型。 |\r\n| `updateModel(uid, patch, options)` | UID、补丁 | `Promise<object \\| null>` | 更新模型。 |\r\n| `batchUpdateModels(updates, options)` | `{ uid, patch }[]` | `Promise<array>` | 批量更新模型。 |\r\n| `upsertModels(models, options)` | 模型数组或单个模型 | `Promise<array>` | 新增或更新模型。 |\r\n| `updateModelPosition(uid, position, options)` | 位置补丁 | `Promise<object \\| null>` | 更新 `lon`、`lat`、`height`、`heading`、`speed`。 |\r\n| `removeModel(uid, options)` | UID | `Promise<object \\| null>` | 删除单个模型。 |\r\n| `removeModels(uids, options)` | UID 数组 | `Promise<array>` | 删除多个模型。 |\r\n| `selectModel(uid)` | UID | `string` | 选中模型。 |\r\n| `setSelectedAnnotation(id)` | 标绘 id | `string \\| null` | 选中标绘。 |\r\n| `focusModel(uid)` | UID | `void` | 地图定位到模型。 |\r\n| `getModelsBySide(side)` | 阵营 | `array` | 按阵营读取模型。 |\r\n| `setBatchSelection(uids)` | UID 数组 | `array` | 设置批量选择。 |\r\n| `clearBatchSelection()` | 无 | `array` | 清空批量选择。 |\r\n| `getBatchSelection()` | 无 | `array` | 读取批量选择 UID。 |\r\n| `isBatchTransformActive()` | 无 | `boolean` | 判断交互式批量变换是否进行中。 |\r\n| `batchMoveModels(uids, delta, options)` | UID 数组、经纬度增量 | `Promise<array>` | 批量移动。 |\r\n| `batchSetModelHeading(uids, heading, options)` | UID 数组、航向角 | `Promise<array>` | 批量设置航向。 |\r\n| `batchLayoutModels(uids, layout, options)` | UID 数组、布局配置 | `Promise<array>` | 按行、列、网格、圆形布局。 |\r\n| `batchRotateModels(uids, angleDegrees, options)` | UID 数组、角度 | `Promise<array>` | 围绕中心旋转。 |\r\n| `startBoxSelectionMode(handler)` | 回调 | `boolean` | 开启框选。 |\r\n| `stopBoxSelectionMode()` | 无 | `void` | 关闭框选。 |\r\n| `startBatchMoveMode(uids, callbacks)` | UID、回调 | `boolean` | 开启交互式批量移动。 |\r\n| `startBatchRotateMode(uids, callbacks)` | UID、回调 | `boolean` | 开启交互式批量旋转。 |\r\n| `stopBatchTransformMode()` | 无 | `void` | 停止批量变换。 |\r\n| `setModelRoute(uid, points, routeMeta, options)` | UID、航线点 | `Promise<object \\| null>` | 设置航线。 |\r\n| `startRouteEdit(uid)` | UID | `Promise<boolean>` | 开始交互式航线编辑。 |\r\n| `addMount(uid, mount, options)` | 主模型 UID、载荷 | `Promise<object \\| null>` | 添加挂载。 |\r\n| `removeMount(uid, mountUID, options)` | 主模型 UID、载荷 UID | `Promise<object \\| null>` | 移除挂载。 |\r\n| `applySituationFrame(frame, options)` | 态势帧 | `Promise<object>` | 增量应用模型、关系、特效、显示、模式变化。 |\r\n| `upsertRelations(relations, options)` | 关系数组或单个关系 | `Promise<array>` | 新增或更新关系线。 |\r\n| `removeRelations(ids, options)` | 关系 id 数组 | `Promise<array>` | 删除关系线。 |\r\n| `upsertEffects(effects, options)` | 特效数组或单个特效 | `Promise<array>` | 新增或更新态势特效。 |\r\n| `removeEffects(ids, options)` | 特效 id 数组 | `Promise<array>` | 删除特效。 |\r\n| `playEventEffect(target, options)` | 目标或坐标 | `Promise<boolean>` | 播放一次性事件效果。 |\r\n| `addAnnotation(annotation, options)` | 标绘对象 | `Promise<object>` | 新增标绘。 |\r\n| `updateAnnotation(id, patch, options)` | 标绘 id、补丁 | `Promise<object \\| null>` | 更新标绘。 |\r\n| `removeAnnotation(id, options)` | 标绘 id | `Promise<object \\| null>` | 删除标绘。 |\r\n| `startAnnotationMode(mode, options, handler)` | 标绘模式 | `boolean` | 开始交互式标绘。 |\r\n| `startMeasureMode(mode, handler)` | `distance` 或 `area` | `boolean` | 开始测量。 |\r\n| `endMeasure()` | 无 | `void` | 结束测量。 |\r\n| `cancelTool()` | 无 | `void` | 取消当前地图工具。 |\r\n| `setPlaybackConfig(patch)` | 回放配置 | `object` | 设置回放速度、进度、尾迹等。 |\r\n| `startPlayback()` | 无 | `void` | 开始回放。 |\r\n| `pausePlayback()` | 无 | `void` | 暂停回放。 |\r\n| `stopPlayback()` | 无 | `void` | 停止回放。 |\r\n| `seekPlayback(progress)` | `0` 到 `1` | `void` | 跳转回放进度。 |\r\n| `exportSceneJson(space)` | 缩进空格数 | `string` | 导出场景 JSON 字符串。 |\r\n| `downloadSceneJson(filename)` | 文件名 | `void` | 下载场景 JSON。 |\r\n| `downloadReport(filename)` | 文件名 | `void` | 下载文本报告。 |\r\n| `exportMapScreenshot(filename)` | 文件名 | `void` | 导出地图截图。 |\r\n| `onReady(handler)` | 回调 | `function` | 监听地图 ready，返回取消监听函数。 |\r\n| `onSelectionChange(handler)` | 回调 | `function` | 监听选择变化。 |\r\n| `onRouteSaved(handler)` | 回调 | `function` | 监听航线保存。 |\r\n| `onMeasure(handler)` | 回调 | `function` | 监听测量结果。 |\r\n| `onAnnotationCreated(handler)` | 回调 | `function` | 监听交互式标绘创建。 |\r\n| `onTemplateDrop(handler)` | 回调 | `function` | 监听模板拖拽投放。 |\r\n| `setFrameMergerConfig(config)` | 合并器配置 | `object` | 配置高频态势帧合并。 |\r\n| `getFrameMergerConfig()` | 无 | `object` | 读取合并器配置。 |\r\n| `flushFrameMerger()` | 无 | `Promise<object \\| null>` | 立即刷新待合并态势帧。 |\r\n\r\n通用 `options` 字段：\r\n\r\n| 字段 | 默认 | 说明 |\r\n| --- | --- | --- |\r\n| `sync` | `true` | 是否同步到地图。批量导入时可先设为 `false`，最后调用 `sync()`。 |\r\n| `recordHistory` | `true` | 是否写入撤销历史。实时态势更新建议设为 `false`。 |\r\n| `label` | 按方法生成 | 历史记录名称。 |\r\n| `force` | `false` | 挂载时是否跳过兼容性校验。 |\r\n| `merge` | `true` | `applySituationFrame` 是否走帧合并器。 |\r\n| `fullSync` | `false` | 态势帧是否强制全量同步。 |\r\n| `bypassFrameMerger` | `false` | 显式绕过帧合并器。 |\r\n\r\n### 运行时规则示例\r\n\r\n```js\r\neditor.configureSceneRuntime({\r\n  templates: [\r\n    { NodeType: \"aircraft\", name: \"飞机\", modelType: \"AIRCRAFT\", mountable: true },\r\n    { NodeType: \"missile\", name: \"导弹\", modelType: \"MISSILE\", templateCategory: \"payload\", mountable: true }\r\n  ],\r\n  mountCompatibility: {\r\n    AIRCRAFT: [\"MISSILE\"]\r\n  },\r\n  mountValidator: (template, host, sceneState) => {\r\n    if (host.mounts.length >= 4) return false;\r\n    return template.modelType === \"MISSILE\";\r\n  },\r\n  validators: [\r\n    sceneState => {\r\n      const hasBlue = sceneState.models.some(model => model.nation === \"blue\");\r\n      return hasBlue ? null : {\r\n        level: \"warning\",\r\n        code: \"NO_BLUE_UNIT\",\r\n        message: \"场景中缺少蓝方目标\"\r\n      };\r\n    }\r\n  ],\r\n  defaultEffectPresets: {\r\n    radar: {\r\n      type: \"radar\",\r\n      geometry: { radius: 100000 },\r\n      style: { color: \"rgba(0, 210, 255, 0.18)\" }\r\n    }\r\n  }\r\n});\r\n```\r\n\r\n### 业务用例：想定编辑\r\n\r\n```js\r\nawait editor.setMode(\"edit\");\r\nawait editor.setMetadata({\r\n  name: \"训练想定 A\",\r\n  author: \"planner\"\r\n});\r\n\r\nconst aircraft = await editor.deployModel(\"aircraft\", {\r\n  UID: \"red_aircraft_001\",\r\n  lon: 116.3,\r\n  lat: 39.9,\r\n  heading: 70,\r\n  nation: \"red\",\r\n  showName: \"红方飞机\"\r\n});\r\n\r\nawait editor.addMount(aircraft.UID, {\r\n  UID: \"missile_001\",\r\n  NodeType: \"missile\",\r\n  modelType: \"MISSILE\",\r\n  name: \"导弹\"\r\n});\r\n\r\nawait editor.setModelRoute(aircraft.UID, [\r\n  { lon: 116.3, lat: 39.9 },\r\n  { lon: 116.8, lat: 40.1 },\r\n  { lon: 117.2, lat: 40.2 }\r\n]);\r\n\r\nawait editor.addAnnotation({\r\n  id: \"no_fly_001\",\r\n  name: \"禁飞区\",\r\n  type: \"polygon\",\r\n  geometry: {\r\n    type: \"polygon\",\r\n    coordinates: [\r\n      [116.4, 39.8],\r\n      [116.7, 39.8],\r\n      [116.7, 40.0],\r\n      [116.4, 40.0],\r\n      [116.4, 39.8]\r\n    ]\r\n  }\r\n});\r\n\r\nconst issues = editor.validateScene();\r\nconst payload = editor.exportSceneJson(2);\r\n```\r\n\r\n### 业务用例：实时态势显示\r\n\r\n```js\r\nawait editor.setMode(\"view\");\r\n\r\neditor.setFrameMergerConfig({\r\n  enabled: true,\r\n  interval: 100,\r\n  maxDelay: 200\r\n});\r\n\r\nsocket.onmessage = event => {\r\n  const message = JSON.parse(event.data);\r\n\r\n  editor.applySituationFrame({\r\n    updates: message.positions.map(item => ({\r\n      uid: item.uid,\r\n      patch: {\r\n        lon: item.lon,\r\n        lat: item.lat,\r\n        heading: item.heading,\r\n        speed: item.speed,\r\n        status: item.status\r\n      }\r\n    })),\r\n    relations: message.links.map(link => ({\r\n      id: link.id,\r\n      type: link.type,\r\n      sourceUID: link.sourceUID,\r\n      targetUID: link.targetUID,\r\n      visible: link.visible\r\n    })),\r\n    effects: message.effects,\r\n    removedEffects: message.removedEffectIds\r\n  }, {\r\n    recordHistory: false\r\n  });\r\n};\r\n```\r\n\r\n### 业务用例：回放历史轨迹\r\n\r\n```js\r\nawait editor.loadScene(snapshot);\r\nawait editor.setMode(\"playback\");\r\n\r\neditor.setPlaybackConfig({\r\n  duration: 600,\r\n  speed: 2,\r\n  maxTrailPoints: 3000\r\n});\r\n\r\nfor (const frame of historyFrames) {\r\n  await editor.applySituationFrame({\r\n    updates: frame.models.map(model => ({\r\n      uid: model.uid,\r\n      patch: {\r\n        lon: model.lon,\r\n        lat: model.lat,\r\n        heading: model.heading\r\n      }\r\n    }))\r\n  }, {\r\n    recordHistory: false,\r\n    merge: false\r\n  });\r\n}\r\n\r\neditor.startPlayback();\r\n```\r\n\r\n### 业务用例：右键菜单和选择联动\r\n\r\n```js\r\neditor.setContextMenuItems([\r\n  {\r\n    id: \"detail\",\r\n    label: \"查看详情\",\r\n    visible: ({ model }) => Boolean(model),\r\n    action: ({ model }) => showModelDetail(model.UID)\r\n  },\r\n  {\r\n    id: \"track\",\r\n    label: \"跟踪目标\",\r\n    visible: ({ model }) => Boolean(model),\r\n    action: async ({ model }) => {\r\n      await editor.updateModel(\"red_aircraft_001\", {\r\n        targetUID: model.UID\r\n      });\r\n    }\r\n  }\r\n]);\r\n\r\nconst offSelection = editor.onSelectionChange(feature => {\r\n  const uid = feature?.get?.(\"UID\");\r\n  if (uid) {\r\n    editor.selectModel(uid);\r\n    updateSidePanel(uid);\r\n  }\r\n});\r\n```\r\n\r\n### 业务用例：批量编队\r\n\r\n```js\r\neditor.setBatchSelection([\"red_001\", \"red_002\", \"red_003\", \"red_004\"]);\r\n\r\nawait editor.batchLayoutModels(\r\n  editor.getBatchSelection(),\r\n  {\r\n    formation: \"grid\",\r\n    columns: 2,\r\n    spacing: 0.12,\r\n    center: { lon: 116.5, lat: 39.95 }\r\n  }\r\n);\r\n\r\nawait editor.batchSetModelHeading(editor.getBatchSelection(), 90);\r\nawait editor.batchRotateModels(editor.getBatchSelection(), 30);\r\n```\r\n\r\n### 业务用例：导入、校验、导出\r\n\r\n```js\r\nconst imported = JSON.parse(await file.text());\r\n\r\nawait editor.loadScene(imported, {\r\n  recordHistory: true\r\n});\r\n\r\nconst issues = editor.validateScene();\r\nif (issues.some(item => item.level === \"error\")) {\r\n  console.warn(\"场景存在错误\", issues);\r\n}\r\n\r\nconst json = editor.exportSceneJson(2);\r\neditor.downloadSceneJson(\"validated-scenario.json\");\r\neditor.downloadReport(\"validated-scenario-report.txt\");\r\n```\r\n\r\n### 多实例集成\r\n\r\n```js\r\nimport { createMapEngine, createScenarioEditor } from \"openlayers2dsceneeditor\";\r\n\r\nconst leftEngine = createMapEngine();\r\nconst rightEngine = createMapEngine();\r\n\r\nconst leftEditor = createScenarioEditor({\r\n  engine: leftEngine,\r\n  context: leftEngine.getContext(),\r\n  mapApp: leftEngine.getMapApp()\r\n});\r\n\r\nconst rightEditor = createScenarioEditor({\r\n  engine: rightEngine,\r\n  context: rightEngine.getContext(),\r\n  mapApp: rightEngine.getMapApp()\r\n});\r\n\r\nleftEditor.init({ target: document.getElementById(\"left-map\") });\r\nrightEditor.init({ target: document.getElementById(\"right-map\") });\r\n```\r\n\r\n### 集成注意事项\r\n\r\n- `UID` 必须稳定。实时态势、关系线、特效、删除和挂载都通过 UID 关联。\r\n- 坐标统一使用经纬度 `[lon, lat]` 或 `{ lon, lat }`，不要传 Web Mercator 米制坐标给业务 API。\r\n- 大量实时更新使用 `applySituationFrame()`，不要频繁 `loadScene()`。\r\n- 业务规则放在宿主系统或 `configureSceneRuntime()` 的校验器中，库只负责状态和显示。\r\n- 正式页面建议 `showWorkbench=false`，内置工作台只用于开发和验收。\r\n- 调用 `destroy()` 后，如果要复用同一个 DOM，需要重新 `init()`。\r\n- SSR 环境中需要在浏览器端动态加载，因为 OpenLayers 和下载接口依赖 DOM。\r\n","_source_registry_name":"default","keywords":["openlayers","vue3","scenario-editor","map","gis","situation-display","annotation","playback"],"license":"ISC","homepage":"https://yjmaixf.github.io"}